# Salin file ini menjadi .env lalu isi dengan nilai kamu sendiri.
# JANGAN commit file .env (yang asli) ke GitHub.

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456789:ABCDEF_your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Target audit (pisahkan dengan koma jika lebih dari satu) ---
# Catatan: jika kamu pakai web dashboard (webapp.py), target dikelola dari
# browser dan disimpan di database, TARGET_HOSTS ini hanya dipakai mode CLI (app.py).
TARGET_HOSTS=example.com
S3_BUCKETS=

# --- AbuseIPDB (https://www.abuseipdb.com) — daftar gratis, 1000 request/hari ---
ABUSEIPDB_API_KEY=isi_dengan_api_key_kamu
ABUSEIPDB_MAX_AGE_DAYS=90
ABUSEIPDB_HIGH_THRESHOLD=25
ABUSEIPDB_CRITICAL_THRESHOLD=75

# --- Threshold ---
SSL_EXPIRY_WARNING_DAYS=30
SSL_EXPIRY_CRITICAL_DAYS=7
NOTIFY_MIN_SEVERITY=MEDIUM

# --- Jadwal scan otomatis (detik, hanya untuk mode CLI --loop) ---
SCAN_INTERVAL_SECONDS=3600

# --- Web dashboard (webapp.py) ---
FLASK_SECRET_KEY=ganti_dengan_string_acak_panjang
WEB_HOST=0.0.0.0
WEB_PORT=5000
